{
  "name": "aws-cognito-template",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "infra/*"
  ],
  "scripts": {
    "vs": "npm run start --workspace vs-helper",
    "vs:tunnel": "npm run start:tunnel --workspace vs-helper",
    "vs:backend:synth": "npm run synth --workspace vs-helper-backend",
    "vs:backend:deploy": "npm run deploy --workspace vs-helper-backend",
    "type-check": "npm run type-check --workspaces --if-present"
  }
}
