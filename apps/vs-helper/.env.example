# OIDC properties from the Cognito console ("Add the example code to your application").
# All EXPO_PUBLIC_* values are inlined into the bundle at build time — they are
# public (the App Client is a public PKCE client with no secret).
EXPO_PUBLIC_COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/<issuer_id>
EXPO_PUBLIC_USER_POOL_CLIENT_ID=<user_pool_client_id>
EXPO_PUBLIC_LOGOUT_URI=vshelper://
EXPO_PUBLIC_APP_SCHEME=vshelper

# Cloud sync backend (infra/vs-helper-backend, see docs/vs-helper-backend.md).
# Leave unset to run fully on-device — sync silently no-ops without it.
EXPO_PUBLIC_API_BASE_URL=https://<api-id>.execute-api.<region>.amazonaws.com
