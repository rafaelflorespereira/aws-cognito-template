# Amplify backend deploy config — copy to `amplify/.env` and fill in, OR export
# these in your shell before running `npx ampx sandbox`.
# These are read by amplify/auth/resource.ts (referenceAuth). None are secret
# (they're IDs/ARNs), but amplify/.env is git-ignored anyway.

# Cognito user pool that already backs the app (from your AWS console).
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# The app client id (same value as EXPO_PUBLIC_USER_POOL_CLIENT_ID).
COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# referenceAuth requires an identity pool linked to the user pool above.
# If you don't have one yet: Cognito console > Identity pools > Create identity
# pool > add the user pool as an authentication provider. That creates the two
# IAM roles below.
COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COGNITO_AUTH_ROLE_ARN=arn:aws:iam::000000000000:role/Cognito_..._Auth_Role
COGNITO_UNAUTH_ROLE_ARN=arn:aws:iam::000000000000:role/Cognito_..._Unauth_Role
