# Copy this file to .env.local and fill in values from CDK outputs

# AWS Region where Cognito is deployed
NEXT_PUBLIC_AWS_REGION=us-east-1

# From CDK output: UserPoolId
NEXT_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXXXX

# From CDK output: UserPoolClientId
NEXT_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From CDK output: CognitoDomain (just the prefix, not the full URL)
NEXT_PUBLIC_COGNITO_DOMAIN=my-app

# Base URL of this app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
