# Copy this file to .env and fill in the "OIDC properties" shown in the Cognito
# console: your user pool → "Add the example code to your application" (step 5).
# Variables prefixed with EXPO_PUBLIC_ are inlined at build time (public, not secret).

# issuer — https://cognito-idp.<region>.amazonaws.com/<userPoolId>
# The app discovers the hosted-UI endpoints from this, so no domain prefix needed.
EXPO_PUBLIC_COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx

# clientID — App client ID (public PKCE client, no secret)
EXPO_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxx

# logoutURL — optional; used for hosted-UI sign-out
EXPO_PUBLIC_LOGOUT_URI=myapp://

# App scheme — must match app.json → expo.scheme (drives redirectURI)
EXPO_PUBLIC_APP_SCHEME=myapp
