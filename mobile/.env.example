# Copy this file to .env and fill in values from CDK outputs.
# Variables prefixed with EXPO_PUBLIC_ are inlined at build time.

# AWS Region where Cognito is deployed
EXPO_PUBLIC_AWS_REGION=us-east-1

# From CDK output: UserPoolClientId
EXPO_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From CDK output: CognitoDomain prefix (e.g. "my-app", not the full URL)
EXPO_PUBLIC_COGNITO_DOMAIN=my-app

# Must match the scheme in app.json → expo.scheme
EXPO_PUBLIC_APP_SCHEME=myapp
