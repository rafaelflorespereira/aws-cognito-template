# Copy this file to .env and fill in values from your Cognito console pool.
# Variables prefixed with EXPO_PUBLIC_ are inlined at build time (public, not secret).

# AWS Region where the Cognito user pool lives
EXPO_PUBLIC_AWS_REGION=us-east-1

# App client ID from the user pool's "App integration" tab (public PKCE client, no secret)
EXPO_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxx

# Cognito domain PREFIX only, not the full URL
# (e.g. for https://us-east-1gdcgzpb1p.auth.us-east-1.amazoncognito.com use "us-east-1gdcgzpb1p")
EXPO_PUBLIC_COGNITO_DOMAIN=xxxxxxxxxx

# Must match the scheme in app.json → expo.scheme
EXPO_PUBLIC_APP_SCHEME=myapp
