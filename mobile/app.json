{
  "expo": {
    "name": "AWS Cognito SSO",
    "slug": "aws-cognito-sso",
    "scheme": "myapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myapp.cognitosso"
    },
    "android": {
      "package": "com.myapp.cognitosso",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
